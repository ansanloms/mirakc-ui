{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "nodeModulesDir": "manual",
  "fmt": {
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": { "tags": ["recommended"] },
    "plugins": ["jsr:@aireone/deno-lint-curly"]
  },
  "exclude": [
    "**/dist/*",
    "client/routeTree.gen.ts",
    "client/lib/api/schema.d.ts",
    "node_modules",
    "storybook-static",
    "coverage"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["vite/client", "vite-plugin-svgr/client", "@types/react"],
    "skipLibCheck": true
  },
  "imports": {
    "@/": "./",
    "react": "npm:react@19.2.7",
    "react/jsx-runtime": "npm:react@19.2.7/jsx-runtime",
    "react/jsx-dev-runtime": "npm:react@19.2.7/jsx-dev-runtime",
    "react-dom": "npm:react-dom@19.2.7",
    "react-dom/client": "npm:react-dom@19.2.7/client",
    "@types/react": "npm:@types/react@19.2.17",
    "@types/react-dom": "npm:@types/react-dom@19.2.3",
    "@tanstack/react-router": "npm:@tanstack/react-router@1.170.15",
    "@tanstack/react-query": "npm:@tanstack/react-query@5.101.0",
    "@tanstack/router-plugin": "npm:@tanstack/router-plugin@1.168.18",
    "@tanstack/react-router-devtools": "npm:@tanstack/react-router-devtools@1.167.0",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@6.0.2",
    "vite": "npm:vite@8.0.16",
    "vite-plugin-svgr": "npm:vite-plugin-svgr@5.2.0",
    "vite-plugin-svgr/client": "npm:/vite-plugin-svgr@5.2.0/client",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
    "hono": "npm:hono@4.12.25",
    "i18next": "npm:i18next@26.3.1",
    "openapi-fetch": "npm:openapi-fetch@0.17.0",
    "openapi-react-query": "npm:openapi-react-query@0.5.4",
    "openapi-typescript": "npm:openapi-typescript@7.13.0",
    "openapi-typescript-helpers": "npm:openapi-typescript-helpers@0.1.0",
    "@std/datetime": "jsr:@std/datetime@0.225.7",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "mpegts.js": "https://esm.sh/mpegts.js@1.8.0",
    "aribb24.js": "npm:aribb24.js@2.0.19",
    "storybook": "npm:storybook@10.4.2",
    "@storybook/react-vite": "npm:@storybook/react-vite@10.4.2",
    "vitest": "npm:vitest@4.1.8",
    "@vitest/coverage-v8": "npm:@vitest/coverage-v8@4.1.8",
    "@testing-library/react": "npm:@testing-library/react@16.3.2",
    "@testing-library/dom": "npm:@testing-library/dom@10.4.1",
    "happy-dom": "npm:happy-dom@20.10.2"
  },
  "tasks": {
    "openapi-typescript": {
      "command": "deno run --env-file=./.env -A openapi-typescript"
    },
    "storybook": {
      "command": "deno run -A storybook"
    },
    "vite": {
      "command": "deno run -A vite"
    },
    "vitest": {
      "command": "deno run -A vitest"
    },
    "dev": "deno task dev:*",
    "dev:server": "deno serve -A --watch=./server --env-file=./.env --port 8000 server/main.ts",
    "dev:client": "deno task vite",
    "build": "deno task vite build",
    "start": "deno serve -A --env-file=./.env --port 8000 server/main.ts",
    "generate": "deno task openapi-typescript $MIRAKC_API_URL --output ./client/lib/api/schema.d.ts",
    "test": "deno task test:*",
    "test:server": "deno test -A --parallel --coverage server/",
    "test:client": "deno task vitest run --coverage",
    "storybook:dev": "deno task storybook dev --port 6006 --no-open",
    "storybook:build": "deno task storybook build --output-dir ./storybook-static",
    "check": "deno check",
    "lint": "deno lint && deno fmt --check",
    "fix": "deno lint --fix && deno fmt"
  }
}
