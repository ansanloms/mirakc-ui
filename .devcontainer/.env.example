MIRAKC_URL=http://example.com:40772

# 録画通知・録画ファイル名の日時整形に使うタイムゾーン (IANA タイムゾーン ID)。
# 未設定なら実行環境の既定 (Docker では UTC)。日本での視聴用途なら Asia/Tokyo を
# 設定する。クライアント (UI) の日時表示はブラウザのローカル TZ に従う (別管理)。
#TZ=Asia/Tokyo

# Vite の server.allowedHosts。カンマ区切りのホスト名、または "true" / "all" で全許可。
# Raspberry Pi 等の非 localhost 経由で開発サーバにアクセスする場合に設定する。
#VITE_ALLOWED_HOSTS=raspberrypi.local,.local

# vim:set ft=sh:
